{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Package",
  "type": "object",
  "required": ["id", "label", "script", "category"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "label": { "type": "string" },
    "description": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["system", "runtime", "database", "tool", "service"]
    },
    "script": { "type": "string" },
    "requires": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiresProvides": {
      "type": "array",
      "items": { "type": "string" }
    },
    "provides": {
      "type": "array",
      "items": { "type": "string" }
    },
    "incompatibleWith": {
      "type": "array",
      "items": { "type": "string" }
    },
    "defaultSelected": { "type": "boolean" },
    "hidden": { "type": "boolean" },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "type": { "type": "string", "enum": ["select", "boolean", "text"] },
          "choices": { "type": "array", "items": { "type": "string" } },
          "default": {}
        }
      }
    }
  }
}
