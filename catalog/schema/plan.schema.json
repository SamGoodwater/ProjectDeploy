{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DeploymentPlan",
  "type": "object",
  "required": ["version", "project", "wsl", "packages", "templates", "github"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "project": {
      "type": "object",
      "required": ["name", "slug", "path"],
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "path": { "type": "string" },
        "domain": { "type": "string" }
      }
    },
    "wsl": {
      "type": "object",
      "required": ["name", "user", "createNew", "memory", "processors", "swap", "distribution"],
      "properties": {
        "name": { "type": "string" },
        "user": { "type": "string" },
        "createNew": { "type": "boolean" },
        "memory": { "type": "string" },
        "processors": { "type": "integer", "minimum": 1 },
        "swap": { "type": "string" },
        "distribution": { "type": "string" }
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "options"],
        "properties": {
          "id": { "type": "string" },
          "options": { "type": "object" }
        }
      }
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "options"],
        "properties": {
          "id": { "type": "string" },
          "options": { "type": "object" }
        }
      }
    },
    "github": {
      "type": "object",
      "required": ["init", "createRemote", "visibility"],
      "properties": {
        "init": { "type": "boolean" },
        "createRemote": { "type": "string", "enum": ["none", "ask", "private", "public"] },
        "visibility": { "type": "string", "enum": ["private", "public"] }
      }
    }
  }
}
